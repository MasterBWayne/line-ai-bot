{
  "version": 2,
  "routes": [
    { "src": "/callback", "dest": "/api/callback.js" },
    { "src": "/webhook", "dest": "/api/callback.js" },
    { "src": "/cron", "dest": "/api/cron.js" },
    { "src": "/(.*)", "dest": "/api/callback.js" }
  ],
  "functions": {
    "api/callback.js": { "maxDuration": 25 },
    "api/cron.js": { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/cron",
      "schedule": "0 12 * * *"
    }
  ]
}
